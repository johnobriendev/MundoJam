# Copy this file to .env.local and fill in the values.
# cp .env.example .env.local

# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string — matches the docker-compose.yml defaults
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mundojam"

# Base URL for NextAuth callbacks
NEXTAUTH_URL="http://localhost:3000"

# Secret for signing JWT sessions — generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=""

# ─── Feature flags ───────────────────────────────────────────────────────────
# All default to false in development. Stub implementations are used when false,
# so no external accounts or API keys are needed for local dev.

USE_REAL_EMAIL=false
USE_REAL_MAP=false
USE_REAL_STORAGE=false

# ─── Optional (only needed when the matching flag is true) ───────────────────

# Resend — required if USE_REAL_EMAIL=true
RESEND_API_KEY=""

# Mapbox — required if USE_REAL_MAP=true
# NEXT_PUBLIC_ prefix makes this available in the browser bundle
NEXT_PUBLIC_MAPBOX_TOKEN=""
